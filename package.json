{
  "name": "pr-deck",
  "version": "0.1.0",
  "description": "Augment and structure human PR reviews with LLM analysis",
  "type": "module",
  "bin": {
    "pr-deck": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup && cp -r src/llm/prompts dist && mkdir -p dist/slides && cp -r src/slides/templates dist/slides/templates",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1024.0",
    "@octokit/rest": "^21.0.2",
    "commander": "^13.1.0",
    "handlebars": "^4.7.8",
    "open": "^10.1.0",
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "@types/handlebars": "^4.1.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.1.1"
  }
}
