{
  "name": "prize",
  "version": "0.1.0",
  "description": "Augment and structure human PR reviews with LLM analysis",
  "type": "module",
  "bin": {
    "prize": "./dist/prize"
  },
  "scripts": {
    "build": "rm -rf dist && bun build --target=bun --minify --sourcemap --outdir=dist src/cli.ts && mv dist/cli.js dist/prize",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1024.0",
    "@octokit/rest": "^21.0.2",
    "commander": "^13.1.0",
    "handlebars": "^4.7.8",
    "open": "^10.1.0",
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/handlebars": "^4.1.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0"
  }
}
