<section class="slide-map">
  <h2>What's in this PR</h2>
  <ol class="piece-map">
    {{#each slide.pieces}}
    <li>
      <strong>{{name}}</strong>
      <span class="piece-desc">— {{description}}</span>
    </li>
    {{/each}}
  </ol>
  <p class="hint">Navigate → to step through each piece. Press ↓ to dive deeper.</p>
</section>
