<div class="slide-overview">
  <h2>Overview</h2>
  <p class="summary">{{{md slide.summary}}}</p>

  <div class="stats-row">
    <div class="stat">
      <span class="stat-num">{{slide.totalFiles}}</span>
      <span class="stat-label">files changed</span>
    </div>
    <div class="stat stat-add">
      <span class="stat-num">+{{slide.additions}}</span>
      <span class="stat-label">additions</span>
    </div>
    <div class="stat stat-del">
      <span class="stat-num">-{{slide.deletions}}</span>
      <span class="stat-label">deletions</span>
    </div>
  </div>

  <div class="overview-grid">
    <div class="overview-block">
      <h4>Motivation</h4>
      <p>{{{md slide.motivation}}}</p>
    </div>
    <div class="overview-block">
      <h4>C4 Context</h4>
      <p>{{{md slide.c4Context}}}</p>
    </div>
  </div>

  {{#if slide.affectedAreas.length}}
  <div class="tags">
    {{#each slide.affectedAreas}}<span class="tag">{{this}}</span>{{/each}}
  </div>
  {{/if}}

</div>
