<section class="slide-summary">
  <h2>Review Complete</h2>
  <p class="summary-text">{{{md slide.summary}}}</p>

  {{#if slide.risks.length}}
  <div class="final-risks">
    <h4>Key risks to keep in mind</h4>
    <ul>{{#each slide.risks}}<li>{{this}}</li>{{/each}}</ul>
  </div>
  {{/if}}
</section>
