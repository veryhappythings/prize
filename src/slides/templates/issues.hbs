<div class="slide-issues">
  <h3>{{slide.pieceName}} — Issues</h3>
  <ul class="issues-list">
    {{#each slide.issues}}
    <li class="issue issue-{{severity}}">
      <span class="severity-badge">{{severity}}</span>
      <div class="issue-body">{{{md description}}}</div>
    </li>
    {{/each}}
  </ul>
</div>
