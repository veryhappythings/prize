<div class="section-overview">
  <h2>Overview</h2>
  <div class="summary">{{{md section.summary}}}</div>

  <div class="stats-row">
    <div class="stat">
      <span class="stat-num">{{section.totalFiles}}</span>
      <span class="stat-label">files changed</span>
    </div>
    <div class="stat stat-add">
      <span class="stat-num">+{{section.additions}}</span>
      <span class="stat-label">additions</span>
    </div>
    <div class="stat stat-del">
      <span class="stat-num">-{{section.deletions}}</span>
      <span class="stat-label">deletions</span>
    </div>
  </div>

  <div class="overview-block">
    <h4>Motivation</h4>
    <div>{{{md section.motivation}}}</div>
  </div>

  {{#if section.affectedAreas.length}}
  <div class="tags">
    {{#each section.affectedAreas}}<span class="tag">{{this}}</span>{{/each}}
  </div>
  {{/if}}

</div>
